# Base URL of the FastAPI backend. Default matches the local dev setup.
VITE_API_URL=http://localhost:8000

# Google OAuth 2.0 Web Client ID. Same value as GOOGLE_CLIENT_ID on the
# backend. Create one at https://console.cloud.google.com/apis/credentials
# (Application type: "Web application"). Add http://localhost:5173 and
# your production Vercel URL to "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
