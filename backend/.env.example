# Parser backend — one of:
#   tesseract   (default, fully local, no API key required)
#   claude      (Anthropic API, requires ANTHROPIC_API_KEY)
#   freellmapi  (FreeLLMAPI text parser, requires a running FreeLLMAPI server)
PARSER_BACKEND=tesseract

# Required when PARSER_BACKEND=claude. Do NOT commit a real key.
# ANTHROPIC_API_KEY=sk-ant-...

# Used when PARSER_BACKEND=freellmapi. The API key is optional for local
# Docker Compose usage; set it to your FreeLLMAPI unified key if you enforce auth.
# FREELLMAPI_BASE_URL=http://localhost:3001
# FREELLMAPI_API_KEY=freellmapi-your-unified-key
# FREELLMAPI_MODEL=auto

# Optional overrides
# DB_PATH=bills.db
# UPLOADS_DIR=uploads
# MAX_UPLOAD_BYTES=20971520    # 20 MB
# LOG_LEVEL=INFO

# CORS — defaults cover localhost:5173/4173 and any *.vercel.app host.
# Override if you have a custom domain or want stricter rules.
# CORS_ALLOW_ORIGINS=http://localhost:5173,https://mycustomdomain.com
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app

# Auth — required.
# Generate AUTH_SECRET with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=replace-with-long-random-hex
# TOKEN_TTL_SEC=604800   # 7 days

# Google OAuth — required for Google Sign-In to work. Same value as the
# frontend's VITE_GOOGLE_CLIENT_ID. Create at:
# https://console.cloud.google.com/apis/credentials (type: Web application)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional comma-separated allowlist. If set, only these Google accounts
# can sign in — everyone else is rejected with a clear error message.
# Leave unset to allow any Gmail / Google Workspace account.
# ALLOWED_EMAILS=you@gmail.com,friend@gmail.com
